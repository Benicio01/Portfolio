---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Footer from '../components/Footer.astro';

interface Repository {
[x: string]: any;
  name: string;
  description: string | null;
  language: string | null;
  html_url: string;
  stargazers_count: number;
  forks_count: number;
}

async function getRepositories(): Promise<Repository[]> {
  const response = await fetch('https://api.github.com/users/Benicio01/repos?sort=updated&per_page=10', {
    headers: {
      'Accept': 'application/vnd.github.v3+json',
    },
  });
  
  if (!response.ok) {
    return [];
  }
  
  const repos: Repository[] = await response.json();
  
  return repos.filter(repo => !repo.fork && repo.name !== 'Benicio01');
}

const repositories = await getRepositories();
---

<Layout title="Benicio Braunstein - Portfolio">
  <main>
    <Hero />
    
    <section id="proyectos" class="py-16 px-6 pb-16">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-slate-900 mb-8">Proyectos</h2>
        
        {repositories.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            {repositories.map((repo) => (
              <ProjectCard
                name={repo.name}
                description={repo.description}
                language={repo.language}
                url={repo.html_url}
                stars={repo.stargazers_count}
                forks={repo.forks_count}
              />
            ))}
          </div>
        ) : (
          <p class="text-slate-500">No se encontraron proyectos.</p>
        )}
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>