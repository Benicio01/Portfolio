---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Education from '../components/Education.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Footer from '../components/Footer.astro';

interface Repository {
[x: string]: any;
  name: string;
  description: string | null;
  language: string | null;
  html_url: string;
  stargazers_count: number;
  forks_count: number;
}

async function getRepositories(): Promise<Repository[]> {
  const response = await fetch('https://api.github.com/users/Benicio01/repos?sort=updated&per_page=10', {
    headers: {
      'Accept': 'application/vnd.github.v3+json',
    },
  });
  
  if (!response.ok) {
    return [];
  }
  
  const repos: Repository[] = await response.json();
  
  return repos.filter(repo => !repo.fork && repo.name !== 'Benicio01');
}

const repositories = await getRepositories();

const projectMeta: Record<string, { title: string; description: string; year: string }> = {
  "Proyecto-Redes-Firewall": {
    title: "Firewall de red (Python)",
    description: "Implementación de un firewall a nivel de red con reglas configurables de filtrado de paquetes, desarrollado en Python sobre sockets raw.",
    year: "2024"
  },
  "Protocolo-RDT": {
    title: "Protocolo RDT sobre UDP",
    description: "Implementación del protocolo RDT (Reliable Data Transfer) con control de flujo y manejo de errores sobre UDP, simulando pérdida de paquetes y timeouts.",
    year: "2024"
  },
  "Fork-Join": {
    title: "Framework Fork-Join en Rust",
    description: "Framework de paralelismo Fork-Join en Rust, con thread pool propio y división recursiva de tareas, sin usar librerías externas de concurrencia.",
    year: "2024"
  },
  "Proyecto-Final-Concurrencia-Distribuida": {
    title: "Sistema Distribuido Concurrente",
    description: "Sistema distribuido en Rust con múltiples actores concurrentes, manejo de estado compartido y tolerancia a fallos.",
    year: "2024"
  },
  "SQL-Rustico": {
    title: "Motor SQL en Rust",
    description: "Motor de base de datos relacional básico implementado en Rust desde cero, con soporte para SELECT, INSERT, WHERE y manejo de archivos CSV.",
    year: "2024"
  },
};
---

<Layout title="Benicio Braunstein - Portfolio">
  <Navbar />
  
  <main>
    <Hero />
    <Education />
    
    <section id="proyectos" class="py-16 px-6 pb-16">
      <div class="max-w-4xl mx-auto">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-16 h-1 bg-gradient-to-r from-emerald-400 to-purple-500 rounded-full"></div>
          <h2 class="text-3xl font-bold text-slate-900">Proyectos</h2>
        </div>
        
        {repositories.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            {repositories.map((repo) => (
              <ProjectCard
                name={repo.name}
                customTitle={projectMeta[repo.name]?.title}
                customDescription={projectMeta[repo.name]?.description}
                year={projectMeta[repo.name]?.year}
                language={repo.language}
                url={repo.html_url}
                stars={repo.stargazers_count}
                forks={repo.forks_count}
              />
            ))}
          </div>
        ) : (
          <p class="text-slate-500">No se encontraron proyectos.</p>
        )}
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>