---
const sobreMi = `Soy estudiante de Ingeniería en Informática en la UBA, apasionado por el desarrollo de software y la resolución de problemas complejos. A lo largo de mi formación, he consolidado bases sólidas trabajando en proyectos integrales. En el backend tengo experiencia con Python, Rust, Java y bases de datos SQL —diseñando protocolos como el RDT sobre UDP, el sistema de Concurrencia Distribuida, y el framework Fork-Join en Rust—, mientras que en el frontend he desarrollado interfaces interactivas utilizando JavaScript y React.
Mi enfoque principal hoy es dar el salto al entorno corporativo: tengo muchas ganas de integrarme a un equipo donde pueda sumar valor desde el primer día, absorber buenas prácticas de la industria y crecer profesionalmente trabajando en productos completos junto a otros desarrolladores.`;

const technologies = [
  { name: "Python", color: "#3572A5" },
  { name: "Rust", color: "#dea584" },
  { name: "Java", color: "#b07219" },
  { name: "SQL", color: "#CC6699" },
  { name: "React", color: "#61DAFB" },
  { name: "JavaScript", color: "#F7DF1E" },
];

const tools = [
  { name: "Git", color: "#F05032" },
  { name: "Linux", color: "#FCC624" },
  { name: "Docker", color: "#2496ED" },
  { name: "VS Code", color: "#007ACC" },
  { name: "PostgreSQL", color: "#336791" },
  { name: "Node.js", color: "#339933" },
];
---

<section id="inicio" class="relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-emerald-200/40 via-purple-100/30 to-emerald-100/20"></div>
  <div class="absolute top-20 right-10 w-72 h-72 bg-emerald-400/20 rounded-full blur-3xl"></div>
  <div class="absolute bottom-10 left-10 w-48 h-48 bg-purple-400/20 rounded-full blur-2xl"></div>
  <div class="absolute top-1/2 left-1/3 w-32 h-32 bg-emerald-500/15 rounded-full blur-xl"></div>
  
  <div class="relative py-20 px-6">
    <div class="max-w-4xl mx-auto flex flex-col md:flex-row items-center gap-12">
      <div class="relative shrink-0">
        <div class="absolute inset-0 rounded-full bg-gradient-to-br from-emerald-400 to-purple-500 animate-pulse-glow"></div>
        <img
          src="/perfil.jpeg"
          alt="Benicio Braunstein"
          class="relative w-44 h-44 md:w-52 md:h-52 rounded-full object-cover border-4 border-white shadow-2xl"
        />
      </div>
      
      <div class="text-center md:text-left">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-emerald-500 to-emerald-600 text-white rounded-full text-sm font-semibold mb-4 shadow-lg shadow-emerald-500/30">
          <span class="w-2 h-2 bg-white rounded-full animate-pulse"></span>
          Disponible para trabajar
        </div>
        
        <h1 class="text-5xl md:text-6xl font-bold tracking-tight mb-3 text-slate-900">
          Benicio Braunstein
        </h1>
        <p class="text-xl md:text-2xl text-slate-600 mb-6 font-medium">
          Estudiante de Ingeniería en Informática - UBA
        </p>
        
        <div class="mb-4">
          <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3 text-left">Lenguajes</p>
          <div class="flex flex-wrap gap-3 justify-center md:justify-start">
            {technologies.map((tech, i) => (
              <span 
                class="px-4 py-2 bg-white/80 backdrop-blur-sm border-2 border-transparent rounded-full text-sm font-semibold text-slate-700 hover:border-current hover:shadow-lg transition-all duration-300 cursor-default"
                style={{ color: tech.color }}
              >
                {tech.name}
              </span>
            ))}
          </div>
        </div>
        
        <div>
          <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3 text-left">Herramientas</p>
          <div class="flex flex-wrap gap-3 justify-center md:justify-start">
            {tools.map((tool, i) => (
              <span 
                class="px-4 py-2 bg-slate-50 border border-slate-200 rounded-full text-sm font-medium text-slate-600 hover:bg-slate-100 hover:border-slate-300 transition-all duration-300 cursor-default"
              >
                {tool.name}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section id="sobre-mi" class="py-12 px-6">
  <div class="max-w-4xl mx-auto">
    <div class="flex items-center gap-4 mb-8">
      <div class="w-16 h-1 bg-gradient-to-r from-emerald-400 to-purple-500 rounded-full"></div>
      <h2 class="text-3xl font-bold text-slate-900">Sobre mí</h2>
    </div>
    
    <div class="bg-white/70 backdrop-blur-md rounded-3xl p-8 md:p-10 shadow-xl shadow-emerald-500/10 border border-white/50 hover:shadow-2xl hover:shadow-emerald-500/20 transition-all duration-500">
      <div class="text-lg text-slate-600 leading-relaxed space-y-5">
        {sobreMi.split('\n').map((paragraph) => (
          <p class="border-l-4 border-emerald-400 pl-5">{paragraph}</p>
        ))}
      </div>
    </div>
  </div>
</section>