---
interface Props {
  name: string;
  description: string | null;
  language: string | null;
  url: string;
  stars?: number;
  forks?: number;
}

const { name, description, language, url, stars = 0, forks = 0 } = Astro.props;

const languageColors: Record<string, string> = {
  Python: '#3572A5',
  Rust: '#dea584',
  JavaScript: '#f1e05a',
  TypeScript: '#2b7489',
  HTML: '#e34c26',
  CSS: '#563d7c',
  Java: '#b07219',
  Go: '#00ADD8',
};

const langColor = language ? (languageColors[language] || '#858585') : '#858585';
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="group block p-6 bg-card rounded-xl border border-gray-100 hover:border-accent/50 hover:shadow-md transition-all duration-300"
>
  <div class="flex items-start justify-between mb-3">
    <h3 class="text-lg font-semibold text-text group-hover:text-accent transition-colors duration-200">
      {name}
    </h3>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gray-300 group-hover:text-accent transition-colors duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M7 17L17 7M7 7h10v10"/>
    </svg>
  </div>
  
  {description && (
    <p class="text-muted text-sm mb-4 line-clamp-2">{description}</p>
  )}
  
  <div class="flex items-center gap-4 text-sm pt-3 border-t border-gray-50">
    {language && (
      <span class="flex items-center gap-2">
        <span class="w-3 h-3 rounded-full" style={`background-color: ${langColor}`}></span>
        <span class="text-muted">{language}</span>
      </span>
    )}
    
    {stars > 0 && (
      <span class="flex items-center gap-1 text-muted">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
        {stars}
      </span>
    )}
    
    {forks > 0 && (
      <span class="flex items-center gap-1 text-muted">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M6 3a3 3 0 0 0-3 3v2.25a3 3 0 0 0 3 3h2.25a3 3 0 0 0 3-3V6a3 3 0 0 0-3-3H6zm9 0a3 3 0 0 0-3 3v2.25a3 3 0 0 0 3 3h2.25a3 3 0 0 0 3-3V6a3 3 0 0 0-3-3h-2.25z"/>
        </svg>
        {forks}
      </span>
    )}
  </div>
</a>