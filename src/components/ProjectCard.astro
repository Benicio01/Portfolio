---
interface Props {
  name: string;
  customTitle?: string;
  customDescription?: string;
  year?: string;
  language: string | null;
  url: string;
  stars?: number;
  forks?: number;
}

const { name, customTitle, customDescription, year, language, url, stars = 0, forks = 0 } = Astro.props;

const languageColors: Record<string, string> = {
  Python: '#3572A5',
  Rust: '#dea584',
  JavaScript: '#f1e05a',
  TypeScript: '#2b7489',
  HTML: '#e34c26',
  CSS: '#563d7c',
  Java: '#b07219',
  Go: '#00ADD8',
};

const langColor = language ? (languageColors[language] || '#858585') : '#858585';
const displayTitle = customTitle || name;
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="group block bg-white/80 backdrop-blur-sm rounded-2xl p-6 border-2 border-slate-100 hover:border-emerald-400 hover:bg-white hover:shadow-2xl hover:shadow-emerald-500/20 hover:-translate-y-2 transition-all duration-300"
>
  <div class="flex items-start justify-between mb-3">
    <div>
      <h3 class="text-xl font-bold text-slate-800 group-hover:text-emerald-600 transition-colors duration-200">
        {displayTitle}
      </h3>
      {year && (
        <span class="text-xs font-medium text-slate-400 mt-1 inline-block">
          {year}
        </span>
      )}
    </div>
    <span class="p-2 bg-emerald-100 rounded-lg group-hover:bg-emerald-500 group-hover:text-white transition-colors duration-200">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-emerald-600 group-hover:text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M7 17L17 7M7 7h10v10"/>
      </svg>
    </span>
  </div>
  
  {customDescription && (
    <p class="text-slate-500 mb-4 line-clamp-3 text-sm leading-relaxed">
      {customDescription}
    </p>
  )}
  
  <div class="flex items-center gap-4 pt-3 border-t border-slate-100">
    {language && (
      <span class="flex items-center gap-2 px-3 py-1.5 bg-slate-100 rounded-full">
        <span class="w-3 h-3 rounded-full" style={`background-color: ${langColor}`}></span>
        <span class="text-sm font-semibold text-slate-600">{language}</span>
      </span>
    )}
    
    {stars > 0 && (
      <span class="flex items-center gap-1 text-slate-400 text-sm font-medium">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
        {stars}
      </span>
    )}
    
    {forks > 0 && (
      <span class="flex items-center gap-1 text-slate-400 text-sm font-medium">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M6 3a3 3 0 0 0-3 3v2.25a3 3 0 0 0 3 3h2.25a3 3 0 0 0 3-3V6a3 3 0 0 0-3-3H6zm9 0a3 3 0 0 0-3 3v2.25a3 3 0 0 0 3 3h2.25a3 3 0 0 0 3-3V6a3 3 0 0 0-3-3h-2.25z"/>
        </svg>
        {forks}
      </span>
    )}
  </div>
</a>