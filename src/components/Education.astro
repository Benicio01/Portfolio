---
const materias = [
  "Sistemas Operativos",
  "Redes",
  "Concurrencia y Distribución",
  "Algoritmos y Programación III",
  "Base de Datos",
];
---

<section id="educacion" class="py-16 px-6">
  <div class="max-w-4xl mx-auto">
    <div class="flex items-center gap-4 mb-8">
      <div class="w-16 h-1 bg-gradient-to-r from-emerald-400 to-purple-500 rounded-full"></div>
      <h2 class="text-3xl font-bold text-slate-900">Educación</h2>
    </div>
    
    <div class="bg-white/70 backdrop-blur-md rounded-3xl p-8 md:p-10 shadow-xl shadow-emerald-500/10 border border-white/50 hover:shadow-2xl hover:shadow-emerald-500/20 transition-all duration-500">
      <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-6">
        <div>
          <h3 class="text-xl font-bold text-slate-900 mb-1">
            Ingeniería en Informática
          </h3>
          <p class="text-emerald-600 font-semibold">
            UBA - Facultad de Ingeniería
          </p>
        </div>
        <span class="px-4 py-1.5 bg-emerald-100 text-emerald-700 rounded-full text-sm font-semibold self-start">
          Cursando actualmente
        </span>
      </div>
      
      <h4 class="text-sm font-bold text-slate-700 mb-4 uppercase tracking-wide">Materias relevantes:</h4>
      <div class="flex flex-wrap gap-2">
        {materias.map((materia) => (
          <span class="px-4 py-2 bg-slate-100 rounded-full text-sm font-medium text-slate-600">
            {materia}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>